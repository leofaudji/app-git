Options -Indexes

# Front Controller - redirect all non-file requests to index.php
RewriteEngine On 

# 1. Disable MultiViews to prevent path confusion
Options -MultiViews

# 2. Force HTTPS in Production (Not localhost/test)
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !\.test$ [NC]
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. DON'T REWRITE EXISTNG FILES OR DIRECTORIES
# This is the most reliable way to prevent MIME type errors for assets
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 4. API Clean URLs
# We use a leading slash/APP_PATH logic or just relative if base is correct
# But to be safe in prod, we check if the file exists before rewriting
RewriteCond %{DOCUMENT_ROOT}/api/$1.php -f [OR]
RewriteCond %{REQUEST_FILENAME} api/([a-z_]+)$
RewriteRule ^api/([a-z_]+)$ api/$1.php [L,QSA]

# 5. Front Controller
# Everything else to index.php if it's not one of the exceptions
RewriteRule ^(?!api/|assets/|manifest\.json|sw\.js).*$ index.php [L,QSA]

# Security headers
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Cache static assets
<FilesMatch "\.(css|js|png|jpg|svg|ico|woff2?)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=86400"
  </IfModule>
</FilesMatch>

# No cache for PHP files
<FilesMatch "\.php$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </IfModule>
</FilesMatch>

# Protect schema.sql, seed_admin.php, deploy.log from direct web access
<FilesMatch "^(schema\.sql|seed_admin\.php|deploy\.log)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>
