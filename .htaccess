Options -Indexes

# Front Controller - redirect all non-file requests to index.php
RewriteEngine On 

# 1. Disable MultiViews & directory listing
Options -MultiViews -Indexes

# 2. Force HTTPS in Production (Not localhost/test)
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !\.test$ [NC]
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. PRIORITY 1: Serve existing files/directories directly
# This prevents MIME type issues by ensuring sw.js, assets, etc. are served as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 4. PRIORITY 2: API Clean URLs
# Rewrite /api/auth to /api/auth.php
RewriteRule ^api/([a-z0-9_]+)/?$ api/$1.php [L,QSA]

# 5. PRIORITY 3: Front Controller (SPA)
# Everything else to index.php, EXCEPT if it's in a path that should never be HTML (api/assets)
# This prevents "Unexpected token <" JSON errors by letting Apache return a real 404 for missing assets/api
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !/(api|assets|manifest\.json|sw\.js) [NC]
RewriteRule ^ index.php [L,QSA]

# Security headers
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Cache static assets
<FilesMatch "\.(css|js|png|jpg|svg|ico|woff2?)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=86400"
  </IfModule>
</FilesMatch>

# No cache for PHP files
<FilesMatch "\.php$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </IfModule>
</FilesMatch>

# Protect schema.sql, seed_admin.php, deploy.log from direct web access
<FilesMatch "^(schema\.sql|seed_admin\.php|deploy\.log)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>
